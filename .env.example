# ─── Auth ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-a-random-string-here
NEXTAUTH_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# For local dev: use a local PostgreSQL connection string, e.g.:
#   postgresql://user:password@localhost:5432/alpha_bail_bonds
# For Netlify: set this to your Neon connection string (see SETUP.md)
DATABASE_URL=postgresql://user:password@localhost:5432/alpha_bail_bonds

# ─── Vonage SMS ──────────────────────────────────────────────────────────────
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# ─── Vapi AI Calls ───────────────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# ─── Agent Forward Phone ─────────────────────────────────────────────────────
AGENT_FORWARD_PHONE=
